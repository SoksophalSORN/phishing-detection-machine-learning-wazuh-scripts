<group name="browser_navigation,phishing_detection,classification,">
  <rule id="100110" level="0">
    <decoded_as>json</decoded_as>
    <field name="integration" type="pcre2">^edge-phishing-classifier$</field>
    <description>Edge phishing classification result.</description>
  </rule>

  <rule id="100111" level="10">
    <if_sid>100110</if_sid>
    <field name="classification.status" type="pcre2">^malicious$</field>
    <field name="classification.source" type="pcre2">^phishtank$</field>
    <description>PhishTank confirmed a phishing host: $(classification.url_host) [source_event_id=$(classification.source_event_id)]</description>
    <mitre><id>T1566.002</id></mitre>
    <group>phishing,confirmed_phishing,phishtank,</group>
  </rule>

  <rule id="100112" level="5">
    <if_sid>100110</if_sid>
    <field name="classification.status" type="pcre2">^error$</field>
    <description>Edge URL classification failed: $(classification.error) [source_event_id=$(classification.source_event_id)]</description>
    <group>phishing_detection_error,</group>
  </rule>

  <!-- Temporary pilot visibility; the final configurable policy lowers this to level 0. -->
  <rule id="100113" level="3">
    <if_sid>100110</if_sid>
    <field name="classification.status" type="pcre2">^(not_found|listed_inactive|unlikely)$</field>
    <description>Host was not confirmed as active phishing by PhishTank: $(classification.url_host) [source_event_id=$(classification.source_event_id)]</description>
    <group>phishing_reputation_checked,pilot_transport,</group>
  </rule>

  <rule id="100114" level="9">
    <if_sid>100110</if_sid>
    <field name="classification.status" type="pcre2">^suspicious$</field>
    <field name="classification.source" type="pcre2">^ml$</field>
    <description>ML detected a suspicious URL on $(classification.url_host) with score $(classification.score) [model=$(classification.model_kind), calibrated=$(classification.calibrated)].</description>
    <mitre><id>T1566.002</id></mitre>
    <group>phishing,ml_detection,</group>
  </rule>
</group>
