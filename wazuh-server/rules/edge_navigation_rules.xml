<group name="browser_navigation,phishing_detection,pilot,">
  <!--
    Temporary Phase 3 transport-validation alert. Every supported navigation
    produces a level-3 alert so the endpoint-to-manager path can be proven.
    Phase 4 should lower or replace this rule to avoid alerting on every URL.
  -->
  <rule id="100100" level="3">
    <!--
      Wazuh's built-in rule 86600 claims JSON containing timestamp and
      event_type. Joining that rule tree lets this narrowly filtered child
      evaluate after JSON decoding instead of competing as another root.
    -->
    <if_sid>86600</if_sid>
    <field name="schema_version" type="pcre2">^1$</field>
    <field name="event_type" type="pcre2">^browser_navigation$</field>
    <field name="source" type="pcre2">^edge_extension$</field>
    <field name="browser" type="pcre2">^edge$</field>
    <url type="pcre2">^https?://</url>
    <description>Edge browser navigation observed: $(url_host) [event_id=$(event_id)]</description>
    <group>browser_navigation,phishing_detection,pilot_transport,</group>
  </rule>
</group>
